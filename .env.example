# Leaderboard storage (Upstash Redis).
#
# In production these are injected automatically when you add the Upstash
# integration from the Vercel Marketplace — you do NOT set them by hand there.
#
# For LOCAL development with a live cloud leaderboard, copy this file to
# `.env.local` and paste the values from your Upstash database page
# (or run `vercel env pull .env.local` after linking the project).
#
# If these are absent, the game still runs — it falls back to a per-device
# local leaderboard so you can build and play offline.

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
